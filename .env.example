# Copy to .env and adjust. Loaded by pydantic-settings (prefix BONDS_) and docker-compose.
# ---- Postgres (docker-compose reads POSTGRES_* ; the app reads BONDS_DB_*) ----
POSTGRES_USER=bonds
POSTGRES_PASSWORD=bonds
POSTGRES_DB=bonds
POSTGRES_PORT=5433

# ---- Application database connection ----
BONDS_DB_HOST=localhost
BONDS_DB_PORT=5433
BONDS_DB_USER=bonds
BONDS_DB_PASSWORD=bonds
BONDS_DB_NAME=bonds

# ---- HTTP client behaviour (be polite to rate-limited gov sources) ----
BONDS_HTTP_MIN_INTERVAL_SECONDS=0.7
BONDS_HTTP_MAX_RETRIES=4
BONDS_HTTP_TIMEOUT_SECONDS=30

# ---- Data lake root (relative to repo root; gitignored) ----
BONDS_DATA_ROOT=data

# ---- Logging ----
BONDS_LOG_LEVEL=INFO
BONDS_LOG_JSON=false
